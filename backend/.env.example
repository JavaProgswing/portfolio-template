# ── CORS allowlist (required in production) ───────────────────────────────
# Comma-separated. The frontend's origin must be listed.
# Local dev defaults are baked into main.py — only set this for production.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Spotify (optional — for /spotify/now-playing) ─────────────────────────
# Get CLIENT_ID/SECRET from https://developer.spotify.com/dashboard
# Then run `python3 get_spotify_token.py` to obtain a refresh token
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# Optional: override the redirect URI registered in your Spotify app
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# ── AI Chat (Gemini) ─────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# Free tier limits apply per model.
GEMINI_API_KEY=

# Recommended text models for Gemini API:
#   gemini-2.5-flash-lite  — fastest/cheapest current default
#   gemini-2.5-flash       — better quality, still fast
#   gemini-2.0-flash       — older stable fallback
#   gemini-2.5-pro         — best reasoning, heavier/slower
#
# Gemma through Gemini API:
#   gemma-3-27b-it         — officially announced for Gemini API
#
# If you get 404, run ListModels or switch back to gemini-2.0-flash.
GEMINI_MODEL=gemini-2.5-flash-lite
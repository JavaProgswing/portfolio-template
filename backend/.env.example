# ── CORS allowlist (required in production) ───────────────────────────────
# Comma-separated. The frontend's origin must be listed.
# Local dev defaults are baked into main.py — only set this for production.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Spotify (optional — for /spotify/now-playing) ─────────────────────────
# Get CLIENT_ID/SECRET from https://developer.spotify.com/dashboard
# Then run `python3 get_spotify_token.py` to obtain a refresh token
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
# Optional: override the redirect URI registered in your Spotify app
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# ── AI Chat (Gemini / Gemma) ──────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey
# Free tier limits apply per model.
GEMINI_API_KEY=
# Model. Options confirmed working on free tier (Gemini API v1beta):
#   gemini-2.0-flash       — recommended default, fast + free
#   gemini-1.5-flash       — older but stable
#   gemini-2.5-flash       — newer (if your key has access)
# Gemma options (require API key with Gemma access — may 404 otherwise):
#   gemma-2-2b-it, gemma-2-9b-it, gemma-2-27b-it
#   gemma-3-1b-it, gemma-3-4b-it
# If you get 404 errors, switch back to gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash
